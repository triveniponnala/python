class CIRCLE:
    def __init__ (self):
        x=int(input("enter radius:"))
        self.radius=x
    def display(self):
        print("area of circle:",3.14*self.radius**2)

a=int(input("enter num of circles:"))
circles=[]
for i in range(a):
    c=CIRCLE() 
    circles.append(c)
    c.display()
    print("________________")
